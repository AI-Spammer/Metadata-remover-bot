BOT_TOKEN=your_bot_token_here
# Optional: mirror processed files to another chat id instead of replying in the same chat.
# TARGET_CHAT_ID=-1001234567890

# Channel gate: users must join this channel before using the bot.
# Use @channelusername or a numeric chat ID.
CHANNEL_USERNAME=@yourchannel
# CHANNEL_ID=-1001234567890

# Admin-only /users command owner Telegram user ID.
ADMIN_ID=123456789

# Spam control: how many removals are allowed per hour per user.
MAX_REMOVALS_PER_HOUR=10

# Daily channel membership re-check timezone.
DAILY_RESET_TZ=Asia/Kolkata
